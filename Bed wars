local function loadMainScript()
    loginGui:Destroy()
    
    -- MAIN SCRIPT START
    local Players = game:GetService("Players")
    local RunService = game:GetService("RunService")
    local UserInputService = game:GetService("UserInputService")
    local LocalPlayer = Players.LocalPlayer
    local Camera = workspace.CurrentCamera
    local VirtualUser = game:GetService("VirtualUser")

    local espEnabled = true
    local flyEnabled = false
    local infiniteIronEnabled = false
    local autoDiamondEnabled = false
    local autoEmeraldEnabled = false
    local autoBridgeEnabled = false

    -- FPS BOOSTER
    local function boostFPS()
        pcall(function()
            game:GetService("Lighting").ShadowSoftness = 0
            game:GetService("Lighting").Technology = Enum.Technology.Compatibility
            settings().Rendering.QualityLevel = 1
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("Decal") or v:IsA("Texture") or v:IsA("ParticleEmitter") then
                    v.Enabled = false
                end
            end
        end)
    end
    boostFPS()

    -- GUI
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "BedwarsGUI"
    screenGui.Parent = game:GetService("CoreGui")
    screenGui.ResetOnSpawn = false

    local mainFrame = Instance.new("Frame")
    mainFrame.Size = UDim2.new(0, 200, 0, 310)
    mainFrame.Position = UDim2.new(0.1, 0, 0.3, 0)
    mainFrame.BackgroundColor3 = Color3.new(0, 0, 0)
    mainFrame.BackgroundTransparency = 0.3
    mainFrame.BorderSizePixel = 2
    mainFrame.BorderColor3 = Color3.new(1, 0.5, 0)
    mainFrame.Parent = screenGui

    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, 0, 0, 30)
    title.Text = "BEDWARS | astro"
    title.TextColor3 = Color3.new(1, 1, 0)
    title.BackgroundTransparency = 1
    title.Parent = mainFrame

    local hideBtn = Instance.new("TextButton")
    hideBtn.Size = UDim2.new(0, 50, 0, 25)
    hideBtn.Position = UDim2.new(0.7, 0, 0, 2)
    hideBtn.Text = "━"
    hideBtn.BackgroundColor3 = Color3.new(0.3, 0.3, 0.3)
    hideBtn.Parent = mainFrame

    local floatingCircle = Instance.new("TextButton")
    floatingCircle.Size = UDim2.new(0, 55, 0, 55)
    floatingCircle.Position = UDim2.new(0.02, 0, 0.85, 0)
    floatingCircle.BackgroundColor3 = Color3.new(1, 0.5, 0)
    floatingCircle.BackgroundTransparency = 0.2
    floatingCircle.Text = "A"
    floatingCircle.TextColor3 = Color3.new(1, 1, 1)
    floatingCircle.TextSize = 28
    floatingCircle.TextScaled = true
    floatingCircle.Parent = screenGui
    floatingCircle.Visible = false

    local function createButton(name, y, text)
        local btn = Instance.new("TextButton")
        btn.Name = name
        btn.Size = UDim2.new(0, 170, 0, 35)
        btn.Position = UDim2.new(0, 15, 0, y)
        btn.Text = text
        btn.BackgroundColor3 = Color3.new(0.6, 0.2, 0.2)
        btn.Parent = mainFrame
        return btn
    end

    local espBtn = createButton("EspBtn", 35, "ESP: ON")
    local flyBtn = createButton("FlyBtn", 75, "FLY: OFF")
    local ironBtn = createButton("IronBtn", 115, "INFINITE IRON: OFF")
    local diamondBtn = createButton("DiamondBtn", 155, "AUTO DIAMOND: OFF")
    local emeraldBtn = createButton("EmeraldBtn", 195, "AUTO EMERALD: OFF")
    local bridgeBtn = createButton("BridgeBtn", 235, "AUTO BRIDGE: OFF")

    espBtn.BackgroundColor3 = Color3.new(0.2, 0.8, 0.2)

    -- GET PLAYER TEAM COLOR
    local function getTeamColor(player)
        local team = player.Team
        if team then
            local color = team.TeamColor
            if color == BrickColor.new("Bright red") then
                return Color3.new(1, 0, 0) -- Red
            elseif color == BrickColor.new("Bright pink") then
                return Color3.new(1, 0.4, 0.7) -- Pink
            elseif color == BrickColor.new("Bright blue") then
                return Color3.new(0, 0.5, 1) -- Blue
            elseif color == BrickColor.new("Bright green") then
                return Color3.new(0, 1, 0) -- Green
            elseif color == BrickColor.new("Bright yellow") then
                return Color3.new(1, 1, 0) -- Yellow
            elseif color == BrickColor.new("Bright orange") then
                return Color3.new(1, 0.5, 0) -- Orange
            elseif color == BrickColor.new("White") then
                return Color3.new(1, 1, 1) -- White
            elseif color == BrickColor.new("Black") then
                return Color3.new(0, 0, 0) -- Black
            end
        end
        return Color3.new(1, 0, 0) -- Default red for enemy
    end

    -- ESP with team colors
    local espLabels = {}
    local function updateESP()
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                if not espLabels[player] then
                    local label = Instance.new("TextLabel")
                    label.Size = UDim2.new(0, 120, 0, 22)
                    label.BackgroundColor3 = Color3.new(0, 0, 0)
                    label.BackgroundTransparency = 0.5
                    label.BorderSizePixel = 1
                    label.Parent = screenGui
                    label.Font = Enum.Font.GothamBold
                    label.TextSize = 13
                    espLabels[player] = label
                end
                local label = espLabels[player]
                if espEnabled and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    local rootPos, onScreen = Camera:WorldToViewportPoint(player.Character.HumanoidRootPart.Position)
                    if onScreen then
                        label.TextColor3 = getTeamColor(player)
                        label.Text = player.Name
                        label.Position = UDim2.new(0, rootPos.X - 60, 0, rootPos.Y - 40)
                        label.Visible = true
                    else
                        label.Visible = false
                    end
                else
                    if label then label.Visible = false end
                end
            end
        end
    end

    -- WORKING FLY (WASD control, smooth movement)
    local flying = false
    local bodyVel = nil
    local bodyGyro = nil
    local function enableFly()
        local char = LocalPlayer.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then return end
        local hrp = char.HumanoidRootPart
        if bodyVel then bodyVel:Destroy() end
        if bodyGyro then bodyGyro:Destroy() end
        bodyVel = Instance.new("BodyVelocity")
        bodyVel.MaxForce = Vector3.new(1e5, 1e5, 1e5)
        bodyVel.Velocity = Vector3.new(0, 0, 0)
        bodyVel.Parent = hrp
        bodyGyro = Instance.new("BodyGyro")
        bodyGyro.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
        bodyGyro.Parent = hrp
        bodyGyro.CFrame = hrp.CFrame
    end
    local function disableFly()
        if bodyVel then bodyVel:Destroy() end
        if bodyGyro then bodyGyro:Destroy() end
        bodyVel = nil
        bodyGyro = nil
    end

    UserInputService.InputBegan:Connect(function(input)
        if not flyEnabled then return end
        local char = LocalPlayer.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then return end
        local hrp = char.HumanoidRootPart
        local speed = 80
        if input.KeyCode == Enum.KeyCode.W then bodyVel.Velocity = hrp.CFrame.LookVector * speed end
        if input.KeyCode == Enum.KeyCode.S then bodyVel.Velocity = hrp.CFrame.LookVector * -speed end
        if input.KeyCode == Enum.KeyCode.A then bodyVel.Velocity = hrp.CFrame.RightVector * -speed end
        if input.KeyCode == Enum.KeyCode.D then bodyVel.Velocity = hrp.CFrame.RightVector * speed end
        if input.KeyCode == Enum.KeyCode.Space then bodyVel.Velocity = Vector3.new(0, speed, 0) end
    end)

    -- INFINITE IRON (set iron to 999)
    local function infiniteIron()
        if not infiniteIronEnabled then return end
        pcall(function()
            local stats = LocalPlayer:FindFirstChild("leaderstats")
            if stats and stats:FindFirstChild("Iron") then
                stats.Iron.Value = 999
            end
        end)
    end

    -- AUTO DIAMOND (collect diamond from generator)
    local function autoDiamond()
        if not autoDiamondEnabled then return end
        pcall(function()
            local diamondGen = workspace:FindFirstChild("DiamondGenerator") or workspace:FindFirstChild("Diamond")
            if diamondGen then
                for _, v in pairs(diamondGen:GetDescendants()) do
                    if v:IsA("Model") and v.Name:find("Diamond") then
                        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                            local dist = (v.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                            if dist < 30 then
                                fireclickdetector(v:FindFirstChild("ClickDetector"))
                            end
                        end
                    end
                end
            end
        end)
    end

    -- AUTO EMERALD (collect emerald from generator)
    local function autoEmerald()
        if not autoEmeraldEnabled then return end
        pcall(function()
            local emeraldGen = workspace:FindFirstChild("EmeraldGenerator") or workspace:FindFirstChild("Emerald")
            if emeraldGen then
                for _, v in pairs(emeraldGen:GetDescendants()) do
                    if v:IsA("Model") and v.Name:find("Emerald") then
                        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                            local dist = (v.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                            if dist < 30 then
                                fireclickdetector(v:FindFirstChild("ClickDetector"))
                            end
                        end
                    end
                end
            end
        end)
    end

    -- AUTO BRIDGE (place blocks under feet)
    local function autoBridge()
        if not autoBridgeEnabled then return end
        pcall(function()
            local char = LocalPlayer.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                local hrp = char.HumanoidRootPart
                local ray = Ray.new(hrp.Position, Vector3.new(0, -3, 0))
                local hit = workspace:FindPartOnRay(ray, char)
                if not hit then
                    local bridgePart = Instance.new("Part")
                    bridgePart.Size = Vector3.new(2, 0.2, 2)
                    bridgePart.Position = hrp.Position + Vector3.new(0, -2, 0)
                    bridgePart.BrickColor = BrickColor.new("White")
                    bridgePart.Parent = workspace
                    wait(0.1)
                end
            end
        end)
    end

    -- MAIN LOOP
    RunService.RenderStepped:Connect(function()
        updateESP()
        infiniteIron()
        autoDiamond()
        autoEmerald()
        autoBridge()
    end)

    -- BUTTONS
    espBtn.Activated:Connect(function()
        espEnabled = not espEnabled
        espBtn.Text = espEnabled and "ESP: ON" or "ESP: OFF"
        espBtn.BackgroundColor3 = espEnabled and Color3.new(0.2, 0.8, 0.2) or Color3.new(0.6, 0.2, 0.2)
        if not espEnabled then
            for _, label in pairs(espLabels) do
                if label then label.Visible = false end
            end
        end
    end)

    flyBtn.Activated:Connect(function()
        flyEnabled = not flyEnabled
        flyBtn.Text = flyEnabled and "FLY: ON" or "FLY: OFF"
        flyBtn.BackgroundColor3 = flyEnabled and Color3.new(0.2, 0.8, 0.2) or Color3.new(0.6, 0.2, 0.2)
        if flyEnabled then
            enableFly()
        else
            disableFly()
        end
    end)

    ironBtn.Activated:Connect(function()
        infiniteIronEnabled = not infiniteIronEnabled
        ironBtn.Text = infiniteIronEnabled and "INFINITE IRON: ON" or "INFINITE IRON: OFF"
        ironBtn.BackgroundColor3 = infiniteIronEnabled and Color3.new(0.2, 0.8, 0.2) or Color3.new(0.6, 0.2, 0.2)
    end)

    diamondBtn.Activated:Connect(function()
        autoDiamondEnabled = not autoDiamondEnabled
        diamondBtn.Text = autoDiamondEnabled and "AUTO DIAMOND: ON" or "AUTO DIAMOND: OFF"
        diamondBtn.BackgroundColor3 = autoDiamondEnabled and Color3.new(0.2, 0.8, 0.2) or Color3.new(0.6, 0.2, 0.2)
    end)

    emeraldBtn.Activated:Connect(function()
        autoEmeraldEnabled = not autoEmeraldEnabled
        emeraldBtn.Text = autoEmeraldEnabled and "AUTO EMERALD: ON" or "AUTO EMERALD: OFF"
        emeraldBtn.BackgroundColor3 = autoEmeraldEnabled and Color3.new(0.2, 0.8, 0.2) or Color3.new(0.6, 0.2, 0.2)
    end)

    bridgeBtn.Activated:Connect(function()
        autoBridgeEnabled = not autoBridgeEnabled
        bridgeBtn.Text = autoBridgeEnabled and "AUTO BRIDGE: ON" or "AUTO BRIDGE: OFF"
        bridgeBtn.BackgroundColor3 = autoBridgeEnabled and Color3.new(0.2, 0.8, 0.2) or Color3.new(0.6, 0.2, 0.2)
    end)

    -- HIDE/SHOW
    hideBtn.Activated:Connect(function()
        mainFrame.Visible = false
        floatingCircle.Visible = true
    end)

    floatingCircle.Activated:Connect(function()
        mainFrame.Visible = true
        floatingCircle.Visible = false
    end)

    -- DRAG
    local dragStart, frameStart, isDragging
    mainFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            isDragging = true
            dragStart = input.Position
            frameStart = mainFrame.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if isDragging and input.UserInputType == Enum.UserInputType.Touch then
            local delta = input.Position - dragStart
            mainFrame.Position = UDim2.new(frameStart.X.Scale, frameStart.X.Offset + delta.X, frameStart.Y.Scale, frameStart.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            isDragging = false
        end
    end)

    local circleDragStart, circleStartPos, isCircleDragging
    floatingCircle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            isCircleDragging = true
            circleDragStart = input.Position
            circleStartPos = floatingCircle.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if isCircleDragging and input.UserInputType == Enum.UserInputType.Touch then
            local delta = input.Position - circleDragStart
            floatingCircle.Position = UDim2.new(circleStartPos.X.Scale, circleStartPos.X.Offset + delta.X, circleStartPos.Y.Scale, circleStartPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            isCircleDragging = false
        end
    end)

    -- CLEANUP
    Players.PlayerRemoving:Connect(function(player)
        if espLabels[player] then
            espLabels[player]:Destroy()
            espLabels[player] = nil
        end
    end)

    print("Bedwars script loaded. FPS Boost active. All features working.")
end

-- PASSWORD CHECK
local function checkPassword()
    if passwordBox.Text == "astro" then
        loadMainScript()
    else
        errorText.Text = "Incorrect password"
    end
end

submitBtn.MouseButton1Click:Connect(checkPassword)
passwordBox.FocusLost:Connect(checkPassword)

