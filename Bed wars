-- TOWER DEFENSE SIMULATOR COMPLETE SCRIPT (CodeX/Hydrogen)
-- Password: astro

-- LOGIN GUI
local loginGui = Instance.new("ScreenGui")
loginGui.Name = "LoginGUI"
loginGui.Parent = game:GetService("CoreGui")

local loginFrame = Instance.new("Frame")
loginFrame.Size = UDim2.new(0, 250, 0, 150)
loginFrame.Position = UDim2.new(0.5, -125, 0.5, -75)
loginFrame.BackgroundColor3 = Color3.new(0, 0, 0)
loginFrame.BackgroundTransparency = 0.1
loginFrame.BorderSizePixel = 3
loginFrame.BorderColor3 = Color3.new(1, 0.5, 0)
loginFrame.Parent = loginGui

local titleLabel = Instance.new("TextLabel")
titleLabel.Size = UDim2.new(1, 0, 0, 40)
titleLabel.Text = "ENTER PASSWORD"
titleLabel.TextColor3 = Color3.new(1, 1, 0)
titleLabel.BackgroundTransparency = 1
titleLabel.Parent = loginFrame

local passwordBox = Instance.new("TextBox")
passwordBox.Size = UDim2.new(0, 200, 0, 40)
passwordBox.Position = UDim2.new(0.5, -100, 0, 50)
passwordBox.PlaceholderText = "Password"
passwordBox.Text = ""
passwordBox.BackgroundColor3 = Color3.new(0.2, 0.2, 0.2)
passwordBox.TextColor3 = Color3.new(1, 1, 1)
passwordBox.Parent = loginFrame

local submitBtn = Instance.new("TextButton")
submitBtn.Size = UDim2.new(0, 100, 0, 35)
submitBtn.Position = UDim2.new(0.5, -50, 0, 100)
submitBtn.Text = "SUBMIT"
submitBtn.BackgroundColor3 = Color3.new(0.2, 0.6, 0.2)
submitBtn.Parent = loginFrame

local errorText = Instance.new("TextLabel")
errorText.Size = UDim2.new(1, 0, 0, 25)
errorText.Position = UDim2.new(0, 0, 0, 140)
errorText.Text = ""
errorText.TextColor3 = Color3.new(1, 0, 0)
errorText.BackgroundTransparency = 1
errorText.Parent = loginFrame

local function loadMainScript()
    loginGui:Destroy()
    
    -- MAIN SCRIPT START
    local Players = game:GetService("Players")
    local RunService = game:GetService("RunService")
    local UserInputService = game:GetService("UserInputService")
    local LocalPlayer = Players.LocalPlayer
    local Camera = workspace.CurrentCamera
    local VirtualUser = game:GetService("VirtualUser")
    local ReplicatedStorage = game:GetService("ReplicatedStorage")

    local espEnabled = true
    local autoDeployEnabled = false
    local infiniteCashEnabled = false
    local instantWinEnabled = false
    local autoSkipEnabled = false

    -- FPS BOOSTER
    local function boostFPS()
        pcall(function()
            game:GetService("Lighting").ShadowSoftness = 0
            game:GetService("Lighting").Technology = Enum.Technology.Compatibility
            settings().Rendering.QualityLevel = 1
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("Decal") or v:IsA("Texture") then
                    v.Enabled = false
                end
            end
        end)
    end
    boostFPS()

    -- GUI
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "TDSGUI"
    screenGui.Parent = game:GetService("CoreGui")
    screenGui.ResetOnSpawn = false

    local mainFrame = Instance.new("Frame")
    mainFrame.Size = UDim2.new(0, 200, 0, 280)
    mainFrame.Position = UDim2.new(0.1, 0, 0.3, 0)
    mainFrame.BackgroundColor3 = Color3.new(0, 0, 0)
    mainFrame.BackgroundTransparency = 0.3
    mainFrame.BorderSizePixel = 2
    mainFrame.BorderColor3 = Color3.new(1, 0.5, 0)
    mainFrame.Parent = screenGui

    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, 0, 0, 30)
    title.Text = "TDS | astro"
    title.TextColor3 = Color3.new(1, 1, 0)
    title.BackgroundTransparency = 1
    title.Parent = mainFrame

    local hideBtn = Instance.new("TextButton")
    hideBtn.Size = UDim2.new(0, 50, 0, 25)
    hideBtn.Position = UDim2.new(0.7, 0, 0, 2)
    hideBtn.Text = "━"
    hideBtn.BackgroundColor3 = Color3.new(0.3, 0.3, 0.3)
    hideBtn.Parent = mainFrame

    local floatingCircle = Instance.new("TextButton")
    floatingCircle.Size = UDim2.new(0, 55, 0, 55)
    floatingCircle.Position = UDim2.new(0.02, 0, 0.85, 0)
    floatingCircle.BackgroundColor3 = Color3.new(1, 0.5, 0)
    floatingCircle.BackgroundTransparency = 0.2
    floatingCircle.Text = "A"
    floatingCircle.TextColor3 = Color3.new(1, 1, 1)
    floatingCircle.TextSize = 28
    floatingCircle.TextScaled = true
    floatingCircle.Parent = screenGui
    floatingCircle.Visible = false

    local function createButton(name, y, text)
        local btn = Instance.new("TextButton")
        btn.Name = name
        btn.Size = UDim2.new(0, 170, 0, 35)
        btn.Position = UDim2.new(0, 15, 0, y)
        btn.Text = text
        btn.BackgroundColor3 = Color3.new(0.6, 0.2, 0.2)
        btn.Parent = mainFrame
        return btn
    end

    local espBtn = createButton("EspBtn", 35, "ESP: ON")
    local deployBtn = createButton("DeployBtn", 75, "AUTO DEPLOY: OFF")
    local cashBtn = createButton("CashBtn", 115, "INFINITE CASH: OFF")
    local winBtn = createButton("WinBtn", 155, "INSTANT WIN: OFF")
    local skipBtn = createButton("SkipBtn", 195, "AUTO SKIP: OFF")

    espBtn.BackgroundColor3 = Color3.new(0.2, 0.8, 0.2)

    -- ESP for towers and enemies
    local espLabels = {}
    local function updateESP()
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("Model") and (v.Name:find("Enemy") or v.Name:find("Zombie") or v.Name:find("Boss")) then
                if not espLabels[v] then
                    local label = Instance.new("TextLabel")
                    label.Size = UDim2.new(0, 100, 0, 20)
                    label.BackgroundColor3 = Color3.new(0, 0, 0)
                    label.BackgroundTransparency = 0.5
                    label.BorderSizePixel = 1
                    label.Parent = screenGui
                    label.Font = Enum.Font.GothamBold
                    label.TextSize = 12
                    espLabels[v] = label
                end
                local label = espLabels[v]
                if espEnabled and v:FindFirstChild("HumanoidRootPart") then
                    local rootPos, onScreen = Camera:WorldToViewportPoint(v.HumanoidRootPart.Position)
                    if onScreen then
                        label.TextColor3 = Color3.new(1, 0, 0)
                        label.Text = v.Name
                        label.Position = UDim2.new(0, rootPos.X - 50, 0, rootPos.Y - 30)
                        label.Visible = true
                    else
                        label.Visible = false
                    end
                else
                    label.Visible = false
                end
            end
        end
    end

    -- AUTO DEPLOY TOWERS
    local function autoDeploy()
        if not autoDeployEnabled then return end
        pcall(function()
            -- Find best tower to deploy
            local towers = LocalPlayer.Backpack:GetChildren()
            for _, tower in pairs(towers) do
                if tower:IsA("Tool") and tower.Name:find("Tower") then
                    -- Find nearest valid position
                    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        local mousePos = UserInputService:GetMouseLocation()
                        VirtualUser:Button1Down(mousePos)
                        wait(0.05)
                        VirtualUser:Button1Up(mousePos)
                    end
                end
            end
        end)
    end

    -- INFINITE CASH
    local function infiniteCash()
        if not infiniteCashEnabled then return end
        pcall(function()
            local stats = LocalPlayer:FindFirstChild("leaderstats")
            if stats and stats:FindFirstChild("Cash") then
                stats.Cash.Value = 9999999
            end
            -- Fire remote for cash
            if ReplicatedStorage:FindFirstChild("Remotes") then
                local cashRemote = ReplicatedStorage.Remotes:FindFirstChild("AddCash")
                if cashRemote then
                    cashRemote:FireServer(9999999)
                end
            end
        end)
    end

    -- INSTANT WIN
    local function instantWin()
        if not instantWinEnabled then return end
        pcall(function()
            -- Kill all enemies instantly
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("Model") and (v.Name:find("Enemy") or v.Name:find("Zombie")) then
                    if v:FindFirstChild("Humanoid") then
                        v.Humanoid.Health = 0
                    end
                end
            end
            -- Skip to last wave
            if ReplicatedStorage:FindFirstChild("Remotes") then
                local waveRemote = ReplicatedStorage.Remotes:FindFirstChild("SetWave")
                if waveRemote then
                    waveRemote:FireServer(999)
                end
            end
        end)
    end

    -- AUTO SKIP WAVES
    local function autoSkip()
        if not autoSkipEnabled then return end
        pcall(function()
            local wave = workspace:FindFirstChild("CurrentWave")
            if wave and wave.Value then
                if ReplicatedStorage:FindFirstChild("Remotes") then
                    local skipRemote = ReplicatedStorage.Remotes:FindFirstChild("SkipWave")
                    if skipRemote then
                        skipRemote:FireServer()
                    end
                end
            end
        end)
    end

    -- MAIN LOOP
    RunService.RenderStepped:Connect(function()
        updateESP()
        autoDeploy()
        infiniteCash()
        instantWin()
        autoSkip()
    end)

    -- BUTTONS
    espBtn.Activated:Connect(function()
        espEnabled = not espEnabled
        espBtn.Text = espEnabled and "ESP: ON" or "ESP: OFF"
        espBtn.BackgroundColor3 = espEnabled and Color3.new(0.2, 0.8, 0.2) or Color3.new(0.6, 0.2, 0.2)
        if not espEnabled then
            for _, label in pairs(espLabels) do
                if label then label.Visible = false end
            end
        end
    end)

    deployBtn.Activated:Connect(function()
        autoDeployEnabled = not autoDeployEnabled
        deployBtn.Text = autoDeployEnabled and "AUTO DEPLOY: ON" or "AUTO DEPLOY: OFF"
        deployBtn.BackgroundColor3 = autoDeployEnabled and Color3.new(0.2, 0.8, 0.2) or Color3.new(0.6, 0.2, 0.2)
    end)

    cashBtn.Activated:Connect(function()
        infiniteCashEnabled = not infiniteCashEnabled
        cashBtn.Text = infiniteCashEnabled and "INFINITE CASH: ON" or "INFINITE CASH: OFF"
        cashBtn.BackgroundColor3 = infiniteCashEnabled and Color3.new(0.2, 0.8, 0.2) or Color3.new(0.6, 0.2, 0.2)
    end)

    winBtn.Activated:Connect(function()
        instantWinEnabled = not instantWinEnabled
        winBtn.Text = instantWinEnabled and "INSTANT WIN: ON" or "INSTANT WIN: OFF"
        winBtn.BackgroundColor3 = instantWinEnabled and Color3.new(0.2, 0.8, 0.2) or Color3.new(0.6, 0.2, 0.2)
    end)

    skipBtn.Activated:Connect(function()
        autoSkipEnabled = not autoSkipEnabled
        skipBtn.Text = autoSkipEnabled and "AUTO SKIP: ON" or "AUTO SKIP: OFF"
        skipBtn.BackgroundColor3 = autoSkipEnabled and Color3.new(0.2, 0.8, 0.2) or Color3.new(0.6, 0.2, 0.2)
    end)

    -- HIDE/SHOW
    hideBtn.Activated:Connect(function()
        mainFrame.Visible = false
        floatingCircle.Visible = true
    end)

    floatingCircle.Activated:Connect(function()
        mainFrame.Visible = true
        floatingCircle.Visible = false
    end)

    -- DRAG
    local dragStart, frameStart, isDragging
    mainFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            isDragging = true
            dragStart = input.Position
            frameStart = mainFrame.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if isDragging and input.UserInputType == Enum.UserInputType.Touch then
            local delta = input.Position - dragStart
            mainFrame.Position = UDim2.new(frameStart.X.Scale, frameStart.X.Offset + delta.X, frameStart.Y.Scale, frameStart.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            isDragging = false
        end
    end)

    local circleDragStart, circleStartPos, isCircleDragging
    floatingCircle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            isCircleDragging = true
            circleDragStart = input.Position
            circleStartPos = floatingCircle.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if isCircleDragging and input.UserInputType == Enum.UserInputType.Touch then
            local delta = input.Position - circleDragStart
            floatingCircle.Position = UDim2.new(circleStartPos.X.Scale, circleStartPos.X.Offset + delta.X, circleStartPos.Y.Scale, circleStartPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Touch then
            isCircleDragging = false
        end
    end)

    print("TDS script loaded. ESP, Auto Deploy, Infinite Cash, Instant Win, Auto Skip.")
end

-- PASSWORD CHECK
local function checkPassword()
    if passwordBox.Text == "astro" then
        loadMainScript()
    else
        errorText.Text = "Incorrect password"
    end
end

submitBtn.MouseButton1Click:Connect(checkPassword)
passwordBox.FocusLost:Connect(checkPassword)
